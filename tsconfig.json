{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "types": ["node", "vitest/globals"],
    "skipLibCheck": true
  },
  "include": ["js/**/*.ts", "tests/**/*.ts", "vite.config.ts"]
}
